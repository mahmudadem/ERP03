// Prisma schema for ERP-Enhanced
// This defines the SQL database structure for PostgreSQL
// Supports dual-database mode (Firestore + PostgreSQL) via DB_TYPE env var

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE MODULE
// ============================================

model Company {
  id              String   @id
  name            String
  ownerId         String
  taxId           String   @unique
  address         String?
  country         String?
  logoUrl         String?
  subscriptionPlan String?
  contactInfo     Json?
  baseCurrency    String
  fiscalYearStart DateTime
  fiscalYearEnd   DateTime
  modules         String[] // Array of enabled module IDs
  features        String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  users           CompanyUser[]
  accounts        Account[]
  vouchers        Voucher[]
  roles           CompanyRole[]
  settings        CompanySettings?
  items           Item[]
  employees       Employee[]
  parties         Party[]
  warehouses      Warehouse[]
  itemCategories  ItemCategory[]
  uoms            Uom[]
  stockLevels     StockLevel[]
  stockMovements  StockMovement[]
  stockAdjustments StockAdjustment[]
  stockTransfers  StockTransfer[]
  openingStockDocuments OpeningStockDocument[]
  inventoryPeriodSnapshots InventoryPeriodSnapshot[]
  purchaseOrders  PurchaseOrder[]
  goodsReceipts   GoodsReceipt[]
  purchaseInvoices PurchaseInvoice[]
  purchaseReturns PurchaseReturn[]
  salesOrders     SalesOrder[]
  deliveryNotes   DeliveryNote[]
  salesInvoices   SalesInvoice[]
  salesReturns    SalesReturn[]
  posOrders       PosOrder[]
  posShifts       PosShift[]
  costCenters     CostCenter[]
  fiscalYears     FiscalYear[]
  budgets         Budget[]
  bankStatements  BankStatement[]
  reconciliations Reconciliation[]
  recurringVoucherTemplates RecurringVoucherTemplate[]
  voucherSequences VoucherSequence[]
  companyGroups   CompanyGroup[]
  ledgerEntries   LedgerEntry[]
  exchangeRates   ExchangeRate[]
  companyCurrencies CompanyCurrency[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  companyModuleSettings CompanyModuleSettings[]
  formDefinitions FormDefinition[]
  voucherTypeDefinitions VoucherTypeDefinition[]
  voucherForms    VoucherForm[]
  attendanceRecords Attendance[]
  impersonationSessions ImpersonationSession[]
  companyModules  CompanyModule[]
  taxCodes        TaxCode[]
  inventorySettings InventorySettings[]
  purchaseSettings PurchaseSettings[]
  salesSettings   SalesSettings[]
  uomConversions  UomConversion[]

  @@index([ownerId])
  @@map("companies")
}

model User {
  id              String   @id
  email           String   @unique
  name            String?
  globalRole      String   @default("USER")
  pictureUrl      String?
  planId          String?
  activeCompanyId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  companies       CompanyUser[]
  preferences     UserPreferences?
  posShifts       PosShift[]

  @@index([activeCompanyId])
  @@map("users")
}

model CompanyUser {
  userId    String
  companyId String
  roleId    String?
  isOwner   Boolean  @default(false)
  role      String?
  permissions String[] @default([])
  isDisabled Boolean @default(false)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
  @@map("company_users")
}

model CompanySettings {
  id                           String   @id @default(uuid())
  companyId                    String   @unique
  strictApprovalMode           Boolean  @default(false)
  uiMode                       String   @default("windows")
  timezone                     String   @default("UTC")
  dateFormat                   String   @default("YYYY-MM-DD")
  language                     String   @default("en")
  baseCurrency                 String   @default("USD")
  fiscalYearStart              Int      @default(1)
  fiscalYearEnd                Int      @default(12)
  exchangeGainLossAccountId    String?
  disabledNotificationCategories String[] @default([])
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}

model UserPreferences {
  id                              String   @id @default(uuid())
  userId                          String   @unique
  language                        String   @default("en")
  uiMode                          String   @default("windows")
  theme                           String   @default("light")
  sidebarMode                     String   @default("classic")
  sidebarPinned                   Boolean  @default(true)
  disabledNotificationCategories  String[] @default([])
  notificationCategoryOverrides   Json?
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ============================================
// RBAC MODULE
// ============================================

model CompanyRole {
  id                  String   @id @default(uuid())
  companyId           String
  name                String
  permissions         String[] @default([])
  moduleBundles       String[] @default([])
  explicitPermissions String[] @default([])
  resolvedPermissions String[] @default([])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@map("company_roles")
}

model SystemRoleTemplate {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  permissions String[] @default([])
  bundleId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_role_templates")
}

// ============================================
// CURRENCY & EXCHANGE RATE MODELS
// ============================================

model Currency {
  code          String   @id
  name          String
  symbol        String
  decimalPlaces Int      @default(2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companyCurrencies CompanyCurrency[]

  @@map("currencies")
}

model CompanyCurrency {
  id           String   @id @default(uuid())
  companyId    String
  currencyCode String
  isEnabled    Boolean  @default(true)
  enabledAt    DateTime @default(now())
  disabledAt   DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  currency Currency @relation(fields: [currencyCode], references: [code])

  @@unique([companyId, currencyCode])
  @@index([companyId])
  @@map("company_currencies")
}

model ExchangeRate {
  id           String   @id @default(uuid())
  companyId    String
  fromCurrency String
  toCurrency   String
  rate         Float
  date         DateTime
  source       String   @default("MANUAL")
  createdAt    DateTime @default(now())
  createdBy    String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, fromCurrency, toCurrency, date])
  @@index([companyId, date])
  @@map("exchange_rates")
}

// ============================================
// ACCOUNTING MODULE
// ============================================

model Account {
  id                        String   @id @default(uuid())
  companyId                 String
  systemCode                String
  userCode                  String
  name                      String
  description               String?
  accountRole               String   @default("POSTING")
  classification            String
  balanceNature             String   @default("DEBIT")
  balanceEnforcement        String   @default("WARN_ABNORMAL")
  parentId                  String?
  currencyPolicy            String   @default("INHERIT")
  fixedCurrencyCode         String?
  allowedCurrencyCodes      String[] @default([])
  status                    String   @default("ACTIVE")
  isProtected               Boolean  @default(false)
  replacedByAccountId       String?
  cashFlowCategory          String?
  plSubgroup                String?
  equitySubgroup            String?
  requiresApproval          Boolean  @default(false)
  requiresCustodyConfirmation Boolean @default(false)
  custodianUserId           String?
  createdAt                 DateTime @default(now())
  createdBy                 String
  updatedAt                 DateTime @updatedAt
  updatedBy                 String

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines         VoucherLine[]
  ledgerEntries LedgerEntry[]
  parent   Account?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children Account[]   @relation("AccountHierarchy")

  @@unique([companyId, systemCode])
  @@unique([companyId, userCode])
  @@index([companyId, classification])
  @@index([companyId, status])
  @@index([companyId, parentId])
  @@map("accounts")
}

model Voucher {
  id               String   @id @default(uuid())
  companyId        String
  type             String
  voucherNo        String?
  date             DateTime
  currency         String
  baseCurrency     String
  exchangeRate     Float    @default(1.0)
  status           String
  totalDebit       Float    @default(0)
  totalCredit      Float    @default(0)
  createdBy        String
  approvedBy       String?
  lockedBy         String?
  reference        String?
  description      String?
  postingPeriodNo  Int?
  metadata         Json?    @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYear FiscalYear? @relation(fields: [fiscalYearId], references: [id])
  lines   VoucherLine[]
  fiscalYearId String?

  @@index([companyId, date])
  @@index([companyId, status])
  @@index([companyId, type])
  @@index([companyId, voucherNo])
  @@index([fiscalYearId])
  @@map("vouchers")
}

model VoucherLine {
  id           String  @id @default(uuid())
  voucherId    String
  lineNo       Int     @default(1)
  accountId    String
  description  String?
  side         String
  amount       Float   @default(0)
  baseAmount   Float   @default(0)
  currency     String
  baseCurrency String
  exchangeRate Float   @default(1.0)
  costCenterId String?
  metadata     Json?    @default("{}")

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id])

  @@index([voucherId])
  @@index([accountId])
  @@index([costCenterId])
  @@map("voucher_lines")
}

model LedgerEntry {
  id           String   @id @default(uuid())
  companyId    String
  accountId    String
  voucherId    String?
  date         DateTime
  description  String?
  debit        Float    @default(0)
  credit       Float    @default(0)
  balance      Float    @default(0)
  currency     String
  baseCurrency String
  exchangeRate Float    @default(1.0)
  fiscalYearId String?
  postingSeq   Int      @default(0)
  createdAt    DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  account  Account  @relation(fields: [accountId], references: [id])
  fiscalYear FiscalYear? @relation(fields: [fiscalYearId], references: [id])

  @@index([companyId, accountId, date])
  @@index([companyId, fiscalYearId])
  @@index([companyId, date])
  @@index([voucherId])
  @@map("ledger_entries")
}

model CostCenter {
  id          String   @id @default(uuid())
  companyId   String
  code        String
  name        String
  description String?
  parentId    String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  createdBy   String
  updatedAt   DateTime @updatedAt
  updatedBy   String

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, parentId])
  @@map("cost_centers")
}

model FiscalYear {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  startDate   DateTime
  endDate     DateTime
  status      String   @default("OPEN")
  isLocked    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vouchers Voucher[]
  ledgerEntries LedgerEntry[]
  voucherSequences VoucherSequence[]
  budgets  Budget[]

  @@index([companyId])
  @@index([companyId, status])
  @@map("fiscal_years")
}

model Budget {
  id           String   @id @default(uuid())
  companyId    String
  fiscalYearId String
  accountId    String
  amount       Float
  period       String
  version      Int      @default(1)
  name         String?
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id])

  @@index([companyId, fiscalYearId])
  @@index([companyId, accountId])
  @@index([companyId, period])
  @@map("budgets")
}

model BankStatement {
  id              String   @id @default(uuid())
  companyId       String
  accountNo       String
  accountName     String?
  statementDate   DateTime
  openingBalance  Float    @default(0)
  closingBalance  Float    @default(0)
  currency        String
  lines           Json?
  status          String   @default("IMPORTED")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, accountNo])
  @@index([companyId, statementDate])
  @@map("bank_statements")
}

model Reconciliation {
  id           String   @id @default(uuid())
  companyId    String
  accountId    String
  period       String
  status       String   @default("IN_PROGRESS")
  matchedEntries Json?
  discrepancy  Float    @default(0)
  notes        String?
  completedAt  DateTime?
  completedBy  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, accountId])
  @@index([companyId, period])
  @@map("reconciliations")
}

model RecurringVoucherTemplate {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  schedule    Json
  voucherData Json
  isActive    Boolean  @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, isActive])
  @@map("recurring_voucher_templates")
}

model VoucherSequence {
  id           String   @id @default(uuid())
  companyId    String
  voucherType  String
  prefix       String
  currentNumber Int     @default(0)
  fiscalYearId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYear FiscalYear? @relation(fields: [fiscalYearId], references: [id])

  @@unique([companyId, voucherType, fiscalYearId])
  @@index([companyId])
  @@map("voucher_sequences")
}

model CompanyGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   CompanyGroup? @relation("CompanyGroupHierarchy", fields: [parentId], references: [id])
  children CompanyGroup[] @relation("CompanyGroupHierarchy")
  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  @@index([parentId])
  @@index([companyId])
  @@map("company_groups")
}

// ============================================
// INVENTORY MODULE
// ============================================

model Item {
  id                        String   @id @default(uuid())
  companyId                 String
  code                      String
  name                      String
  description               String?
  barcode                   String?
  type                      String   @default("PRODUCT")
  categoryId                String?
  brand                     String?
  tags                      String[] @default([])
  baseUomId                 String?
  baseUom                   String
  purchaseUomId             String?
  purchaseUom               String?
  salesUomId                String?
  salesUom                  String?
  costCurrency              String   @default("USD")
  costingMethod             String   @default("MOVING_AVG")
  trackInventory            Boolean  @default(true)
  revenueAccountId          String?
  cogsAccountId             String?
  inventoryAssetAccountId   String?
  defaultPurchaseTaxCodeId  String?
  defaultSalesTaxCodeId     String?
  minStockLevel             Float?
  maxStockLevel             Float?
  reorderPoint              Float?
  imageUrl                  String?
  metadata                  Json?
  active                    Boolean  @default(true)
  createdBy                 String
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category        ItemCategory? @relation(fields: [categoryId], references: [id])
  baseUomRef      Uom?     @relation("ItemBaseUom", fields: [baseUomId], references: [id])
  purchaseUomRef  Uom?     @relation("ItemPurchaseUom", fields: [purchaseUomId], references: [id])
  salesUomRef     Uom?     @relation("ItemSalesUom", fields: [salesUomId], references: [id])
  stockLevels     StockLevel[]
  stockMovements  StockMovement[]
  purchaseOrderLines PurchaseOrderLine[]
  purchaseInvoiceLines PurchaseInvoiceLine[]
  purchaseReturnLines PurchaseReturnLine[]
  salesOrderLines SalesOrderLine[]
  salesInvoiceLines SalesInvoiceLine[]
  salesReturnLines SalesReturnLine[]
  posOrderItems   PosOrderItem[]
  stockAdjustmentLines StockAdjustmentLine[]
  stockTransferLines StockTransferLine[]
  openingStockLines OpeningStockLine[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, categoryId])
  @@index([companyId, active])
  @@map("items")
}

model ItemCategory {
  id          String   @id @default(uuid())
  companyId   String
  code        String
  name        String
  description String?
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items   Item[]
  parent   ItemCategory? @relation("ItemCategoryHierarchy", fields: [parentId], references: [id])
  children ItemCategory[] @relation("ItemCategoryHierarchy")

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, parentId])
  @@map("item_categories")
}

model Uom {
  id                String   @id @default(uuid())
  companyId         String
  code              String
  name              String
  baseUomId         String?
  conversionFactor  Float    @default(1.0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  baseUomRef    Uom?     @relation("UomHierarchy", fields: [baseUomId], references: [id])
  children      Uom[]    @relation("UomHierarchy")
  itemsBase     Item[]   @relation("ItemBaseUom")
  itemsPurchase Item[]   @relation("ItemPurchaseUom")
  itemsSales    Item[]   @relation("ItemSalesUom")
  conversionsFrom UomConversion[] @relation("UomConversionFrom")
  conversionsTo   UomConversion[] @relation("UomConversionTo")

  @@unique([companyId, code])
  @@index([companyId])
  @@map("uoms")
}

model UomConversion {
  id          String   @id @default(uuid())
  companyId   String
  fromUomId   String
  toUomId     String
  factor      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromUom Uom     @relation("UomConversionFrom", fields: [fromUomId], references: [id])
  toUom   Uom     @relation("UomConversionTo", fields: [toUomId], references: [id])

  @@unique([companyId, fromUomId, toUomId])
  @@index([companyId])
  @@map("uom_conversions")
}

model Warehouse {
  id          String   @id @default(uuid())
  companyId   String
  code        String
  name        String
  parentId    String?
  address     String?
  active      Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockLevels     StockLevel[]
  stockMovements  StockMovement[]
  parent   Warehouse? @relation("WarehouseHierarchy", fields: [parentId], references: [id])
  children Warehouse[] @relation("WarehouseHierarchy")

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, active])
  @@map("warehouses")
}

model StockLevel {
  id              String   @id @default(uuid())
  companyId       String
  itemId          String
  warehouseId     String
  qtyOnHand       Float    @default(0)
  reservedQty     Float    @default(0)
  avgCostBase     Float    @default(0)
  avgCostCCY      Float    @default(0)
  lastCostBase    Float    @default(0)
  lastCostCCY     Float    @default(0)
  postingSeq      Int      @default(0)
  maxBusinessDate String?
  totalMovements  Int      @default(0)
  lastMovementId  String?
  version         Int      @default(0)
  updatedAt       DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  item      Item      @relation(fields: [itemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([companyId, itemId, warehouseId])
  @@index([companyId, itemId])
  @@index([companyId, warehouseId])
  @@map("stock_levels")
}

model StockMovement {
  id                  String   @id @default(uuid())
  companyId           String
  date                String
  postingSeq          Int      @default(0)
  createdAt           DateTime @default(now())
  createdBy           String
  postedAt            DateTime?
  itemId              String
  warehouseId         String
  direction           String
  movementType        String
  qty                 Float
  uom                 String
  referenceType       String
  referenceId         String?
  referenceLineId     String?
  reversesMovementId  String?
  transferPairId      String?
  unitCostBase        Float    @default(0)
  totalCostBase       Float    @default(0)
  unitCostCCY         Float    @default(0)
  totalCostCCY        Float    @default(0)
  movementCurrency    String
  fxRateMovToBase     Float    @default(1.0)
  fxRateCCYToBase     Float    @default(1.0)
  fxRateKind          String   @default("DOCUMENT")
  avgCostBaseAfter    Float    @default(0)
  avgCostCCYAfter     Float    @default(0)
  qtyBefore           Float    @default(0)
  qtyAfter            Float    @default(0)
  settledQty          Float?
  unsettledQty        Float?
  unsettledCostBasis  String?
  settlesNegativeQty  Float?
  newPositiveQty      Float?
  negativeQtyAtPosting Boolean @default(false)
  costSettled         Boolean  @default(false)
  isBackdated         Boolean  @default(false)
  costSource          String
  notes               String?
  metadata            Json?

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  item      Item      @relation(fields: [itemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([companyId, itemId, postingSeq])
  @@index([companyId, warehouseId, postingSeq])
  @@index([companyId, referenceType, referenceId])
  @@index([companyId, date])
  @@index([companyId, costSettled])
  @@map("stock_movements")
}

model StockAdjustment {
  id          String   @id @default(uuid())
  companyId   String
  documentNo  String
  date        DateTime
  reason      String?
  status      String   @default("DRAFT")
  notes       String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   StockAdjustmentLine[]

  @@unique([companyId, documentNo])
  @@index([companyId])
  @@index([companyId, status])
  @@map("stock_adjustments")
}

model StockAdjustmentLine {
  id              String   @id @default(uuid())
  adjustmentId    String
  itemId          String
  warehouseId     String
  qtyBefore       Float
  qtyAfter        Float
  unitCostBase    Float?
  notes           String?

  adjustment StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  item  Item @relation(fields: [itemId], references: [id])

  @@index([adjustmentId])
  @@index([itemId])
  @@map("stock_adjustment_lines")
}

model StockTransfer {
  id             String   @id @default(uuid())
  companyId      String
  documentNo     String
  fromWarehouseId String
  toWarehouseId  String
  date           DateTime
  status         String   @default("DRAFT")
  notes          String?
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   StockTransferLine[]

  @@unique([companyId, documentNo])
  @@index([companyId])
  @@index([companyId, status])
  @@map("stock_transfers")
}

