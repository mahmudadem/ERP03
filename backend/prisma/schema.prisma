model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String
  userId     String
  companyId  String?
  timestamp  DateTime @default(now())
  meta       Json?

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([timestamp])
  @@index([companyId])
  @@map("audit_logs")
}

model CompanyModuleSettings {
  id        String   @id @default(uuid())
  companyId String
  moduleId  String
  settings  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, moduleId])
  @@index([companyId])
  @@map("company_module_settings")
}

model ModulePermissionsDefinition {
  id          String   @id @default(uuid())
  moduleId    String   @unique
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("module_permissions_definitions")
}

model ModuleSettingsDefinition {
  id            String   @id @default(uuid())
  moduleId      String   @unique
  settingsSchema Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("module_settings_definitions")
}

// ============================================
// SUPER-ADMIN MODULE
// ============================================

model BusinessDomain {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  modules     String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("business_domains")
}

model ModuleRegistry {
  id           String   @id @default(uuid())
  code         String   @unique
  name         String
  version      String
  description  String?
  dependencies String[] @default([])
  businessDomainId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("module_registries")
}

model BundleRegistry {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  modules     String[] @default([])
  pricing     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("bundle_registries")
}

model PlanRegistry {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  features    Json?
  pricing     Json?
  limits      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("plan_registries")
}

model PermissionRegistry {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  module      String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("permission_registries")
}

model RoleTemplateRegistry {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("role_template_registries")
}

// ============================================
// COMPANY-WIZARD MODULE
// ============================================

model ChartOfAccountsTemplate {
  id        String   @id @default(uuid())
  country   String?
  industry  String?
  name      String
  accounts  Json
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([country])
  @@index([industry])
  @@map("chart_of_accounts_templates")
}

model CompanyCreationSession {
  id        String   @id @default(uuid())
  userId    String
  status    String   @default("IN_PROGRESS")
  data      Json
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("company_creation_sessions")
}

model CompanyWizardTemplate {
  id        String   @id @default(uuid())
  name      String
  models    String[]
  isDefault Boolean  @default(false)
  steps     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_wizard_templates")
}

model InventoryTemplate {
  id         String   @id @default(uuid())
  industry   String?
  name       String
  items      Json
  categories Json?
  warehouses Json?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([industry])
  @@map("inventory_templates")
}

// ============================================
// COMPANY MODULE
// ============================================

model CompanyModule {
  companyId              String
  moduleCode             String
  installedAt            DateTime @default(now())
  initialized            Boolean  @default(false)
  initializationStatus   String   @default("pending")
  config                 Json?
  updatedAt              DateTime? @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([companyId, moduleCode])
  @@map("company_modules")
}

// ============================================
// SYSTEM METADATA
// ============================================

model SystemMetadata {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_metadata")
}

// ============================================
// IMPERSONATION MODULE
// ============================================

model ImpersonationSession {
  id           String   @id @default(uuid())
  superAdminId String
  companyId    String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  endedAt      DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([superAdminId])
  @@index([companyId])
  @@index([active])
  @@map("impersonation_sessions")
}
