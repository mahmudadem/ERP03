# Database Configuration

# Database Type: FIRESTORE or SQL
DB_TYPE=FIRESTORE

# PostgreSQL Connection (only used if DB_TYPE=SQL)
DATABASE_URL="postgresql://user:password@localhost:5432/erp_enhanced?schema=public"

# AI Assistant Configuration
# Encryption key for API keys at rest (AES-256-GCM, base64-encoded 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# REQUIRED in production. In development, omitting this disables encryption (NOT secure).
AI_ENCRYPTION_KEY=
