{
  "name": "erp-enhanced-backend",
  "version": "1.0.0",
  "description": "ERP Enhanced Backend",
  "main": "lib/backend/src/index.js",
  "scripts": {
    "prisma:generate": "prisma generate",
    "prebuild": "npm run prisma:generate",
    "build": "tsc",
    "pretypecheck": "npm run prisma:generate",
    "typecheck": "tsc --noEmit",
    "serve": "firebase emulators:start --import=../emulator-data --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "test": "jest --runInBand",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "seed:demo": "ts-node --transpile-only src/seeder/runDemoSeeder.ts",
    "seed:onboarding": "ts-node --transpile-only src/seeder/seedOnboardingData.ts",
    "seed:system": "ts-node --transpile-only src/seeder/runSystemSeeder.ts",
    "seed:business-domains": "ts-node --transpile-only src/seeder/seedBusinessDomains.ts",
    "seed:vouchers": "ts-node --transpile-only src/scripts/seedDefaultVoucherTypes.ts",
    "reset:accounting": "ts-node --transpile-only src/seeder/resetAccountingModule.ts",
    "seed:sql": "ts-node --transpile-only prisma/seeds/runSqlSeed.ts",
    "smoke:companies": "ts-node --transpile-only src/scripts/smokeTwoCompanies.ts"
  },
  "engines": {
    "node": "18"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "axios": "^1.16.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "firebase-admin": "^11.8.0",
    "firebase-functions": "^4.3.1",
    "multer": "^1.4.5-lts.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/uuid": "^10.0.0",
    "firebase-tools": "^14.27.0",
    "jest": "^30.2.0",
    "prisma": "^5.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.0"
  },
  "private": true
}
