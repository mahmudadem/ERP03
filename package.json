{
  "name": "erp-modular-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "emulators": "powershell -ExecutionPolicy Bypass -File scripts/start-emulators.ps1",
    "emulators:remote": "powershell -ExecutionPolicy Bypass -File scripts/start-emulators.ps1",
    "db:export": "firebase emulators:export ./emulator-data --force",
    "graph:update": "py -3.14 -m graphify update .",
    "graph:check": "py -3.14 -m graphify check-update .",
    "graph:query": "py -3.14 -m graphify query",
    "graph:explain": "py -3.14 -m graphify explain",
    "graph:path": "py -3.14 -m graphify path"
  },
  "dependencies": {
    "firebase-admin": "^13.6.0",
    "express": "^5.1.0",
    "react-router-dom": "^7.9.6",
    "firebase-functions": "^7.0.0",
    "cors": "^2.8.5",
    "vite": "^7.2.4",
    "@vitejs/plugin-react": "^5.1.1",
    "path": "^0.12.7",
    "react-dom": "^19.2.0",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
